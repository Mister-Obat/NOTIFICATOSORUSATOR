<Window x:Class="Notificatosorusator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Notificatosorusator - Audio Bridge" Height="520" Width="900"
        Background="#0F1115" Foreground="#E6EAF2"
        Icon="Images/logo.ico">
    <Window.Resources>
        <SolidColorBrush x:Key="PageBg" Color="#0F1115"/>
        <SolidColorBrush x:Key="PanelBg" Color="#161A22"/>
        <SolidColorBrush x:Key="PanelBgSoft" Color="#1C2230"/>
        <SolidColorBrush x:Key="BorderSoft" Color="#2A3242"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E6EAF2"/>
        <SolidColorBrush x:Key="TextMuted" Color="#9FA9BA"/>
        <SolidColorBrush x:Key="Accent" Color="#4CC2FF"/>
        <SolidColorBrush x:Key="Success" Color="#4ADE80"/>
        <SolidColorBrush x:Key="ScrollTrack" Color="#141B28"/>
        <SolidColorBrush x:Key="ScrollThumb" Color="#3A465A"/>
        <SolidColorBrush x:Key="ScrollThumbHover" Color="#4C5B73"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,14,0"/>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DarkScrollThumbStyle" TargetType="Thumb">
            <Setter Property="MinHeight" Value="22"/>
            <Setter Property="MinWidth" Value="22"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbRoot"
                                Background="{StaticResource ScrollThumb}"
                                CornerRadius="5"
                                Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbRoot" Property="Background" Value="{StaticResource ScrollThumbHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="VerticalDarkScrollBarTemplate" TargetType="ScrollBar">
            <Border Background="{StaticResource ScrollTrack}" CornerRadius="6">
                <Track x:Name="PART_Track"
                       IsDirectionReversed="True"
                       VerticalAlignment="Stretch"
                       HorizontalAlignment="Stretch"
                       Minimum="{TemplateBinding Minimum}"
                       Maximum="{TemplateBinding Maximum}"
                       Value="{TemplateBinding Value}"
                       ViewportSize="{TemplateBinding ViewportSize}">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageUpCommand"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Focusable="False"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource DarkScrollThumbStyle}"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageDownCommand"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Focusable="False"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Border>
        </ControlTemplate>

        <ControlTemplate x:Key="HorizontalDarkScrollBarTemplate" TargetType="ScrollBar">
            <Border Background="{StaticResource ScrollTrack}" CornerRadius="6">
                <Track x:Name="PART_Track"
                       VerticalAlignment="Stretch"
                       HorizontalAlignment="Stretch"
                       Minimum="{TemplateBinding Minimum}"
                       Maximum="{TemplateBinding Maximum}"
                       Value="{TemplateBinding Value}"
                       ViewportSize="{TemplateBinding ViewportSize}">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageLeftCommand"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Focusable="False"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource DarkScrollThumbStyle}"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageRightCommand"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Focusable="False"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Border>
        </ControlTemplate>

        <Style x:Key="DarkScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Background" Value="{StaticResource ScrollTrack}"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Template" Value="{StaticResource VerticalDarkScrollBarTemplate}"/>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Template" Value="{StaticResource HorizontalDarkScrollBarTemplate}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource PageBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="14,14,14,10" Padding="16,12"
                Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Notificatosorusator" FontSize="19" FontWeight="SemiBold"/>
                    <TextBlock Text="Audio bridge for task notifications" FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" Background="#1F2937" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="999" Padding="10,4">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource Success}" Margin="0,0,7,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Listeners active" FontSize="12" Foreground="#C9F8D9" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="14,0,14,10" Padding="12,9"
                Background="{StaticResource PanelBgSoft}" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Info" FontWeight="SemiBold" Foreground="{StaticResource Accent}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="L'application surveille les toasts Windows et joue un son selon la règle active."
                           Foreground="{StaticResource TextMuted}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Margin="14,0,14,10" Padding="12,10"
                Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Sources actives :" Margin="0,0,14,0" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}"/>
                <CheckBox x:Name="SourceAntigravityCheckbox"
                          Content="Antigravity"
                          IsChecked="True"
                          Checked="SourceCheckboxChanged"
                          Unchecked="SourceCheckboxChanged"/>
                <CheckBox x:Name="SourcePowerShellCheckbox"
                          Content="PowerShell"
                          IsChecked="True"
                          Checked="SourceCheckboxChanged"
                          Unchecked="SourceCheckboxChanged"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Volume :" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}"/>
                <Slider x:Name="VolumeSlider"
                        Minimum="0"
                        Maximum="100"
                        Value="100"
                        Width="180"
                        TickFrequency="5"
                        IsSnapToTickEnabled="False"
                        ValueChanged="VolumeSlider_ValueChanged"/>
                <TextBlock x:Name="VolumeValueText"
                           Text="100%"
                           Width="46"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
        </Border>

        <Border Grid.Row="3" Margin="14,0,14,14" Padding="0"
                Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#121722" Padding="12,8" CornerRadius="10,10,0,0">
                    <TextBlock Text="Activity log" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                </Border>
                <TextBox x:Name="LogOutput" Grid.Row="1" Margin="0"
                         Background="#0E131D" Foreground="#C7D2E4"
                         BorderThickness="0" FontFamily="Consolas"
                         IsReadOnly="True" VerticalScrollBarVisibility="Visible"
                         TextWrapping="Wrap" Padding="12"/>
            </Grid>
        </Border>
    </Grid>
</Window>
